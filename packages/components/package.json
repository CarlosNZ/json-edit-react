{
  "name": "@json-edit-react/components",
  "version": "0.9.0-beta.0",
  "description": "Ready-to-use custom node components for json-edit-react",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CarlosNZ/json-edit-react.git",
    "directory": "packages/components"
  },
  "homepage": "https://github.com/CarlosNZ/json-edit-react/tree/main/packages/components",
  "main": "build/index.cjs.js",
  "module": "build/index.esm.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.esm.js",
      "require": "./build/index.cjs.js"
    },
    "./widgets": {
      "types": "./build/widgets.d.ts",
      "import": "./build/widgets.esm.js",
      "require": "./build/widgets.cjs.js"
    }
  },
  "typesVersions": {
    "*": {
      "widgets": [
        "build/widgets.d.ts"
      ]
    }
  },
  "files": [
    "build/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c && rm -rf build/dts",
    "clean": "rm -rf build",
    "compile": "tsc --noEmit",
    "prepack": "pnpm build",
    "preview-publish": "node ../../scripts/with-npm-readme.mjs . -- pnpm pack"
  },
  "peerDependencies": {
    "json-edit-react": "workspace:^",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@uiw/codemirror-theme-console": "^4.23.13",
    "@uiw/codemirror-theme-dracula": "^4.23.13",
    "@uiw/codemirror-theme-github": "^4.23.13",
    "@uiw/codemirror-theme-monokai": "^4.23.13",
    "@uiw/codemirror-theme-quietlight": "^4.23.13",
    "@uiw/codemirror-theme-solarized": "^4.23.13",
    "@uiw/codemirror-theme-tokyo-night": "^4.23.13",
    "@uiw/react-codemirror": "^4.23.13",
    "colord": "^2.9.3",
    "react-colorful": "^5.6.1",
    "react-datepicker": "^7.5.0",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.0",
    "use-debounce": "^10.0.5"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "19.1.1",
    "json-edit-react": "workspace:*",
    "react": "^19.1.0",
    "rollup": "^4.10.0",
    "rollup-plugin-bundle-size": "^1.0.3",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-sizes": "^1.0.6",
    "rollup-plugin-styles": "^4.0.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "json-edit-react",
    "components",
    "custom-nodes",
    "react",
    "json-editor"
  ]
}
