{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@json-edit-react/themes": ["../packages/themes/src"],
      "@json-edit-react/themes/*": ["../packages/themes/src/*"],
      "@json-edit-react/components": ["../packages/components/src"],
      "@json-edit-react/components/*": ["../packages/components/src/*"],
      "@json-edit-react": ["../src/"],
      "@json-edit-react/*": ["../src/*"],
      // `@json-edit-react` is mapped to core's source (`../src`), which lives in
      // the pnpm workspace and would otherwise resolve `react` from the root's
      // `@types/react` copy — a different physical copy than the demo's. Two
      // copies of the same version still clash on the `unique symbol` in React's
      // ref types, so pin all react type resolution to the demo's single copy.
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react-dom/*": ["./node_modules/@types/react-dom/*"]
    },
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../custom-component-library/components/DatePicker/DateTimePicker.tsx"
  ]
}
