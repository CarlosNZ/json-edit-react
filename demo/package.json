{
  "name": "json-edit-react-demo",
  "version": "1.25.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "homepage": "https://carlosnz.github.io/json-edit-react",
  "scripts": {
    "start": "vite",
    "start:local": "VITE_JRE_SOURCE=local vite",
    "start:build": "VITE_JRE_SOURCE=build vite",
    "start:pack": "VITE_JRE_SOURCE=pack vite",
    "dev": "yarn start:local",
    "prebuild": "yarn lint",
    "build": "tsc -b && vite build",
    "build:local": "VITE_JRE_SOURCE=local yarn build",
    "build:build": "VITE_JRE_SOURCE=build yarn build",
    "build:pack": "VITE_JRE_SOURCE=pack yarn build",
    "build-v2": "VITE_BASE_PATH=/json-edit-react-v2/ yarn build",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d build",
    "deploy-v2": "yarn build-v2 && gh-pages -d build --repo https://github.com/CarlosNZ/json-edit-react-v2.git",
    "lint": "eslint .",
    "serve": "vite preview",
    "compile": "tsc -b --noEmit"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.1.1",
    "@chakra-ui/react": "^2.10.7",
    "@codemirror/lang-json": "^6.0.1",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@uiw/codemirror-theme-console": "^4.23.13",
    "@uiw/codemirror-theme-dracula": "^4.23.13",
    "@uiw/codemirror-theme-github": "^4.23.13",
    "@uiw/codemirror-theme-monokai": "^4.23.13",
    "@uiw/codemirror-theme-quietlight": "^4.23.13",
    "@uiw/codemirror-theme-solarized": "^4.23.13",
    "@uiw/codemirror-theme-tokyo-night": "^4.23.13",
    "@uiw/react-codemirror": "^4.23.13",
    "ajv": "^8.16.0",
    "colord": "^2.9.3",
    "firebase": "^10.13.0",
    "framer-motion": "^11.0.3",
    "json-edit-react": "2.0.0-beta.0",
    "@json-edit-react/themes": "0.9.0-beta.0",
    "@json-edit-react/components": "0.9.0-beta.0",
    "@json-edit-react/utils": "0.9.0-beta.0",
    "json5": "^2.2.3",
    "react": "^19.0.0",
    "react-colorful": "^5.6.1",
    "react-datepicker": "^7.5.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-icons": "^5.0.1",
    "react-live": "^4.1.8",
    "react-select": "^5.10.0",
    "react-markdown": "^10.1.0",
    "shiki": "^4.2.0",
    "use-debounce": "^10.0.5",
    "use-undo": "^1.1.1",
    "wouter": "^3.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fs-extra": "^11.3.0",
    "gh-pages": "^6.1.1",
    "globals": "^15.15.0",
    "node-fetch": "^3.3.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5"
  }
}
